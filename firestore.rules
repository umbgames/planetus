rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required) - The user's unique ID.
    //   - displayName: string (required) - The user's display name.
    //   - commonResources: number (required) - Amount of common resources.
    //   - rareResources: number (required) - Amount of rare resources.
    //   - hasSatellite: boolean (required) - Whether the user has launched a satellite.
    //   - createdAt: string (required) - When the account was created.
    //
    // Collection: bases
    // Document ID: baseId
    // Fields:
    //   - id: string (required) - The base's unique ID.
    //   - ownerId: string (required) - The ID of the user who owns this base. Can be 'npc' for initial bases.
    //   - position: map (required) - The position of the base.
    //     - x: number
    //     - y: number
    //     - z: number
    //   - zone: string (required) - The resource zone the base is in.
    //   - level: number (required) - The level of the base.
    //   - health: number (required) - The health of the base.
    //   - lastMinedAt: string (required) - When the base last generated resources.
    //   - createdAt: string (required) - When the base was built.
    //
    // Collection: market_offers
    // Document ID: offerId
    // Fields:
    //   - id: string (required) - The offer's unique ID.
    //   - sellerId: string (required) - The ID of the user who created this offer.
    //   - sellerName: string (required) - The display name of the seller.
    //   - offerType: string (required) - 'sell_common' | 'sell_rare'
    //   - amountOffered: number (required) - The amount of resources offered.
    //   - amountRequested: number (required) - The amount of resources requested in exchange.
    //   - status: string (required) - 'active' | 'fulfilled' | 'claimed'
    //   - buyerId: string (optional) - The ID of the user who bought this offer.
    //   - createdAt: string (required) - When the offer was created.
    //
    // Collection: resources
    // Document ID: resourceId
    // Fields:
    //   - id: string (required)
    //   - type: string (required) - 'common' | 'rare'
    //   - position: map (required)
    //   - active: boolean (required)
    //   - createdAt: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasAll(fields) && request.resource.data.keys().hasOnly(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string;
    }

    function isValidUser(data) {
      return (hasOnlyAllowedFields(['uid', 'displayName', 'commonResources', 'rareResources', 'hasSatellite', 'machineGunAmmo', 'missileAmmo', 'taxAgreements', 'createdAt']) ||
              hasOnlyAllowedFields(['uid', 'displayName', 'clanId', 'commonResources', 'rareResources', 'hasSatellite', 'machineGunAmmo', 'missileAmmo', 'taxAgreements', 'lastActiveAt', 'currentPlanetId', 'shipConfig', 'createdAt', 'playerSave'])) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             (!('clanId' in data) || data.clanId == null || data.clanId is string) &&
             data.commonResources is number && data.commonResources >= 0 &&
             data.rareResources is number && data.rareResources >= 0 &&
             data.hasSatellite is bool &&
             data.machineGunAmmo is number && data.machineGunAmmo >= 0 &&
             data.missileAmmo is number && data.missileAmmo >= 0 &&
             data.taxAgreements is map &&
             (!('lastActiveAt' in data) || isValidDateString(data.lastActiveAt)) &&
             (!('currentPlanetId' in data) || data.currentPlanetId == null || data.currentPlanetId is string) &&
             (!('shipConfig' in data) || data.shipConfig is map) &&
             isValidDateString(data.createdAt);
    }

    function isValidBase(data) {
      return data.id is string &&
             data.ownerId is string &&
             (!('clanId' in data) || data.clanId == null || data.clanId is string) &&
             data.zone in ['high', 'mid', 'low'] &&
             data.level is number &&
             data.health is number &&
             data.shieldActive is bool &&
             data.shieldHealth is number &&
             data.maxShieldHealth is number &&
             (!('hasMiner' in data) || data.hasMiner is bool) &&
             (!('hasMissileBattery' in data) || data.hasMissileBattery is bool) &&
             (!('hasTaxOffice' in data) || data.hasTaxOffice is bool) &&
             (!('lastMinedAt' in data) || isValidDateString(data.lastMinedAt)) &&
             isValidDateString(data.createdAt);
    }

    function isValidClan(data) {
      return hasOnlyAllowedFields(['id', 'name', 'leaderId', 'members', 'commonResources', 'rareResources', 'createdAt']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.leaderId is string &&
             data.members is list &&
             data.commonResources is number &&
             data.rareResources is number &&
             isValidDateString(data.createdAt);
    }

    function isValidSpaceStation(data) {
      return hasOnlyAllowedFields(['id', 'ownerId', 'ownerName', 'clanId', 'planetId', 'position', 'orbitRadius', 'orbitSpeed', 'initialAngle', 'health', 'maxHealth', 'isControlled', 'controlledBy', 'createdAt']) &&
             data.id is string &&
             data.ownerId is string &&
             (!('clanId' in data) || data.clanId == null || data.clanId is string) &&
             data.planetId is string &&
             data.position is map &&
             data.orbitRadius is number &&
             data.orbitSpeed is number &&
             data.initialAngle is number &&
             data.health is number &&
             data.maxHealth is number &&
             data.isControlled is bool &&
             (!('controlledBy' in data) || data.controlledBy == null || data.controlledBy is string) &&
             isValidDateString(data.createdAt);
    }

    function isValidPlanetState(data) {
      return (hasOnlyAllowedFields(['id', 'hegemonId', 'taxRate', 'taxStatus', 'lastTaxProcessAt']) ||
              hasOnlyAllowedFields(['id', 'taxRate', 'taxStatus', 'lastTaxProcessAt'])) &&
             data.id is string &&
             (!('hegemonId' in data) || data.hegemonId == null || data.hegemonId is string) &&
             data.taxRate is number &&
             data.taxStatus in ['active', 'inactive'] &&
             isValidDateString(data.lastTaxProcessAt);
    }

    function isValidMarketOffer(data) {
      return (hasOnlyAllowedFields(['id', 'sellerId', 'sellerName', 'offerType', 'amountOffered', 'amountRequested', 'status', 'createdAt']) ||
              hasOnlyAllowedFields(['id', 'sellerId', 'sellerName', 'offerType', 'amountOffered', 'amountRequested', 'status', 'buyerId', 'createdAt'])) &&
             data.id is string &&
             data.sellerId is string &&
             data.sellerName is string && data.sellerName.size() > 0 && data.sellerName.size() < 50 &&
             data.offerType in ['sell_common', 'sell_rare'] &&
             data.amountOffered is number && data.amountOffered > 0 &&
             data.amountRequested is number && data.amountRequested > 0 &&
             data.status in ['active', 'fulfilled', 'claimed'] &&
             (!('buyerId' in data) || data.buyerId is string) &&
             isValidDateString(data.createdAt);
    }

    function isValidResource(data) {
      return hasOnlyAllowedFields(['id', 'type', 'position', 'active', 'createdAt']) &&
             data.id is string &&
             data.type in ['common', 'rare'] &&
             data.position is map &&
             data.position.keys().hasAll(['x', 'y', 'z']) &&
             data.position.x is number && data.position.y is number && data.position.z is number &&
             data.active is bool &&
             isValidDateString(data.createdAt);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Anyone can read users (for satellite leaderboard).
      allow read: if true;
      // Users can create their own profile.
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.commonResources == 0 && request.resource.data.rareResources == 0 && request.resource.data.hasSatellite == false;
      // Users can update their own profile (mining, spending resources, launching satellite).
      // Or other users can destroy their satellite.
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt && request.resource.data.uid == resource.data.uid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasSatellite']) && request.resource.data.hasSatellite == false)
      );
    }

    match /bases/{baseId} {
      // Anyone can read bases to render them on the planet.
      allow read: if true;
      // Users can create a base if they own it, or create NPC bases.
      allow create: if isAuthenticated() && isValidBase(request.resource.data) && (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerId == 'npc') && request.resource.data.level == 1 && request.resource.data.health == 100;
      // Users can update their own bases (mining, upgrading, repairing).
      // Other users can update bases to attack them (reduce health, change owner if health is 0).
      allow update: if isAuthenticated() && isValidBase(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt && request.resource.data.id == resource.data.id && request.resource.data.position == resource.data.position && request.resource.data.zone == resource.data.zone && (
        (isDocOwner() && request.resource.data.ownerId == resource.data.ownerId) || // Owner upgrading/mining
        (!isDocOwner() && request.resource.data.health < resource.data.health && request.resource.data.ownerId == resource.data.ownerId) || // Attacker damaging
        (!isDocOwner() && request.resource.data.health == 100 && request.resource.data.ownerId == request.auth.uid && resource.data.health <= 20) // Attacker taking over
      );
    }

    match /market_offers/{offerId} {
      // Anyone can read market offers
      allow read: if true;
      // Users can create offers if they are the seller
      allow create: if isAuthenticated() && isValidMarketOffer(request.resource.data) && request.resource.data.sellerId == request.auth.uid && request.resource.data.id == offerId && request.resource.data.status == 'active';
      // Sellers can cancel (delete) their own offers
      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      // Buyers can fulfill an offer by updating its status to 'fulfilled' and setting buyerId
      allow update: if isAuthenticated() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'buyerId']) &&
         resource.data.status == 'active' &&
         request.resource.data.status == 'fulfilled' &&
         request.resource.data.buyerId == request.auth.uid)
      );
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidResource(request.resource.data) && request.resource.data.active == true;
      allow update: if isAuthenticated() && isValidResource(request.resource.data) && request.resource.data.id == resource.data.id && request.resource.data.type == resource.data.type && request.resource.data.createdAt == resource.data.createdAt && (
        (request.resource.data.active == false && resource.data.active == true && request.resource.data.position == resource.data.position) ||
        (request.resource.data.active == true && resource.data.active == false)
      );
      allow delete: if isAuthenticated();
    }

    match /planet_states/{planetId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPlanetState(request.resource.data);
      allow update: if isAuthenticated() && isValidPlanetState(request.resource.data);
    }

    match /clans/{clanId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidClan(request.resource.data) && request.resource.data.leaderId == request.auth.uid;
      allow update: if isAuthenticated() && isValidClan(request.resource.data) && (
        resource.data.leaderId == request.auth.uid || // Leader can update
        (request.auth.uid in request.resource.data.members && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'commonResources', 'rareResources'])) // Members can join/leave or contribute
      );
      allow delete: if isAuthenticated() && resource.data.leaderId == request.auth.uid;
    }

    match /space_stations/{stationId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidSpaceStation(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isValidSpaceStation(request.resource.data) && (
        resource.data.ownerId == request.auth.uid || // Owner
        (resource.data.clanId != null && get(/databases/$(database)/documents/clans/$(resource.data.clanId)).data.members.hasAny([request.auth.uid])) || // Clan member
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isControlled', 'controlledBy', 'health'])) // Anyone can attack or try to control if empty
      );
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
  }
}
